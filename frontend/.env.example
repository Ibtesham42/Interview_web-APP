# Frontend environment variables. Copy to .env for local development.
#
# Local dev: only the Supabase vars are required. Leave VITE_API_URL and
# VITE_WS_URL unset — the app falls back to the Vite dev proxy (/api) and
# ws://localhost:8000.

# Supabase (required) — anon/publishable key, safe to ship in the browser bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Production only — set these in the Vercel dashboard (Project -> Settings ->
# Environment Variables). Point at the Render backend service.
# VITE_API_URL=https://your-api.onrender.com
# VITE_WS_URL=wss://your-api.onrender.com
