# Copy this file to .env and fill in your values

# Groq (REQUIRED) - powers the LLM (llama-3.3-70b-versatile) and Whisper STT
GROQ_API_KEY=gsk_your-key-here

# OpenAI (optional) - only needed if you run the ml_questions embedding seed
OPENAI_API_KEY=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sbp_your_key_here

# Server
HOST=0.0.0.0
PORT=8000

# CORS (production) — frontend origins allowed to call this API.
#
# FRONTEND_ORIGINS: comma-separated exact origins, e.g. a custom domain.
#
# FRONTEND_ORIGIN_REGEX: matches Vercel deployments. The wildcard default
# (https://.*\.vercel\.app) allows any *.vercel.app site to call the API —
# fine for first-time setup but TOO PERMISSIVE for production. Tighten to
# your project slug so only your production + preview deployments match:
#
#   ^https://<your-project>(-[a-z0-9-]+)?\.vercel\.app$
#
# Example (this project): ^https://interview-web-app(-[a-z0-9-]+)?\.vercel\.app$
# Matches production (interview-web-app-lyart.vercel.app), branch previews
# (interview-web-app-git-foo-lyart.vercel.app), and commit previews; blocks
# any unrelated *.vercel.app site.
FRONTEND_ORIGINS=
FRONTEND_ORIGIN_REGEX=https://.*\.vercel\.app

# Piper TTS (optional - for local voice synthesis)
# Set to True to use Piper instead of Edge TTS
USE_PIPER_TTS=false
# Path to .onnx voice file (e.g., ./voices/en_US-lessac-medium.onnx)
PIPER_VOICE_PATH=
